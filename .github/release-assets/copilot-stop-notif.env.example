# copilot-stop-notif 邮件配置
# 复制本文件为 copilot-stop-notif.env 后填写真实 SMTP 参数

# SMTP 服务器配置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_USE_SSL=true

# 仅在你明确知道邮件服务器允许明文认证时才设置为 true
SMTP_ALLOW_INSECURE_PLAIN=false

# 可选，不填时默认使用 SMTP_USER
# EMAIL_FROM=notify@example.com

# 收件人，多个用英文逗号分隔
EMAIL_TO=your_email@example.com

# 是否在邮件中附带工作目录、会话ID等本地上下文，默认 false
# 即使设置为 true，邮件中也会自动脱敏本机用户名、邮箱和部分绝对路径
EMAIL_INCLUDE_CONTEXT=false

# 可选，分号分隔的额外 transcript 白名单目录（支持 %APPDATA% 等环境变量）
# TRANSCRIPT_ALLOWED_ROOTS=%LOCALAPPDATA%\copilot-stop-notif\transcripts
