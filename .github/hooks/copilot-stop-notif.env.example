# copilot-stop-notif 邮件配置示例
# 复制为 copilot-stop-notif.env 后填写真实 SMTP 参数

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=notify@example.com
SMTP_PASSWORD=replace-with-app-password
SMTP_USE_SSL=true

# 仅在你明确知道邮件服务器允许明文认证时才设置为 true
SMTP_ALLOW_INSECURE_PLAIN=false

# 可选，不填时默认使用 SMTP_USER；163/Gmail 等严格 SMTP 服务通常要求与 SMTP_USER 一致
# EMAIL_FROM=notify@example.com

# 多个收件人请使用英文逗号分隔
EMAIL_TO=recipient@example.com

# 是否在邮件中附带工作目录、会话ID、线程ID等本地上下文，默认 false
EMAIL_INCLUDE_CONTEXT=false

# 可选，使用分号分隔多个额外允许读取 transcript 的根目录
# 程序会保留默认允许目录，并支持 %APPDATA% 这类环境变量写法
# 未配置时，程序默认只允许读取 VS Code workspaceStorage 和系统临时目录
# 如果 transcript 放在自定义导出目录，只加入该专用目录，不要把项目目录加入白名单
# TRANSCRIPT_ALLOWED_ROOTS=%LOCALAPPDATA%\\copilot-stop-notif\\transcripts